# ==========================================
# Ikiru Bot - Environment Variables
# ==========================================

# ------------------------------------------
# Discord Configuration (Required)
# ------------------------------------------
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_PUBLIC_KEY=your_discord_public_key_here
DISCORD_APPLICATION_ID=your_discord_app_id_here
DISCORD_OWNER_ID=your_discord_user_id_here
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/xxx  # Optional, for error logging

# ------------------------------------------
# Scraper Credentials (Optional - for advanced scraping)
# ------------------------------------------
IKIRU_EMAIL=your_email@example.com
IKIRU_PASSWORD=your_secure_password_here

# ------------------------------------------
# Security & Authentication (Required)
# ------------------------------------------
CRON_SECRET=your_random_cron_secret_key_here
DASHBOARD_SESSION_SECRET=your_random_session_secret_here
DASHBOARD_PASSWORD=your_secure_dashboard_password_here
WORKER_TOKEN=your_random_secret_token_here

# ------------------------------------------
# External Monitoring (Optional - FastCron)
# ------------------------------------------
FASTCRON_API_TOKEN=your_fastcron_api_token_here  # For cron job monitoring and next run display

# ------------------------------------------
# Error Tracking (Optional - Sentry Free Tier)
# ------------------------------------------
# Get your DSN from: https://sentry.io/signup/ (free tier: 5,000 errors/month)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ------------------------------------------
# Server Configuration (Optional)
# ------------------------------------------
PORT=3000
NODE_ENV=production  # development | production
LOG_LEVEL=info       # debug | info | warn | error
BASE_URL=https://your-app-url.vercel.app
ALLOWED_ORIGINS=https://your-domain.vercel.app  # Comma-separated for multiple domains (production only)

# ------------------------------------------
# Source URLs & Fallbacks (Optional - has defaults)
# ------------------------------------------
IKIRU_BASE_URL=https://03.ikiru.wtf
SHINIGAMI_BASE_URL=https://f.shinigami.asia
SECONDARY_SOURCE_URL=https://api.shngm.io
SECONDARY_PUBLIC_BASE=https://f.shinigami.asia
ALLOW_DASHBOARD_CRON=true

# ------------------------------------------
# VPS Proxy Configuration (Optional - to bypass Cloudflare block on Vercel)
# ------------------------------------------
# IKIRU_PROXY_URL=http://your-vps-ip:port
# IKIRU_PROXY_TOKEN=your_secure_bearer_token_here

# ------------------------------------------
# Scraper & Concurrency (Optional - has defaults)
# ------------------------------------------
IKIRU_MAX_PAGES=2
IKIRU_CHAPTER_LIST_MAX_PAGES=2
SHINIGAMI_CHAPTER_LIST_MAX_PAGES=2
CHANNEL_VALIDATION_CONCURRENCY=8
CHANNEL_VALIDATION_REFRESH_SECONDS=3600
IKIRU_REQUEST_TIMEOUT=10000
IKIRU_MAX_RETRIES=2
SHINIGAMI_DIRECT_FALLBACK_MAX_URLS=50

# ------------------------------------------
# Enhanced Cron Security (Optional)
# ------------------------------------------
# CRON_ALLOWED_IPS=127.0.0.1,192.168.1.1  # Comma-separated IP allowlist
CRON_MAX_DAILY_RUNS=144                   # Max cron runs per day (default: 144)

# ------------------------------------------
# Supabase (Required)
# ------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here  # REQUIRED: backend operations need this to bypass RLS
